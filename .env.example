# Server
PORT=3000

# JWT secret — change this in production
JWT_SECRET=change-me-to-a-real-secret-in-production

# Resend API key for email verification (get one at https://resend.com)
RESEND_API_KEY=re_your_api_key_here

# PostgreSQL connection string
# Local: postgresql://postgres:postgres@localhost:5432/scheduling_app
# Render/Railway: auto-set when you add a database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scheduling_app

# Cloudflare R2 (S3-compatible) — for profile photo uploads
# Account ID: Cloudflare dashboard → R2 → copy Account ID from the right sidebar
R2_ACCOUNT_ID=your_cloudflare_account_id
# R2 API token (create one with Object Read & Write permissions)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# The bucket name you created in the R2 dashboard
R2_BUCKET_NAME=your_bucket_name
# Public URL for the bucket (set up a custom domain or use the r2.dev subdomain)
R2_PUBLIC_URL=https://your-bucket.your-subdomain.r2.dev
